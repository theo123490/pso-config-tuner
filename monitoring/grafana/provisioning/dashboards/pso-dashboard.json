{
  "title": "PSO Swarm",
  "uid": "pso-swarm",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Swarm Iteration",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "pso_iteration",
          "legendFormat": "iteration"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "gBest Fitness",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "pso_gbest_fitness",
          "legendFormat": "gBest fitness"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "gBest Fitness Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pso_gbest_fitness",
          "legendFormat": "gBest fitness"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "Iteration Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pso_iteration",
          "legendFormat": "iteration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "Per-Particle Fitness",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "pso_particle_fitness",
          "legendFormat": "{{particle_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "Particle Positions (current)",
      "type": "table",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "pso_particle_position",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "merge", "options": {} },
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "variable",
            "rowField": "particle_id",
            "valueField": "Value"
          }
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "particle_id" }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "auto" }
        }
      }
    }
  ]
}
